{
  "version": "2.0",
  "project": {
    "name": "unity-py-sim",
    "expertise": [
      "backend",
      "testing"
    ]
  },
  "stack": {
    "languages": [
      "python"
    ],
    "test_runner": {
      "python": {
        "command": "python -m pytest",
        "test_dir": "tests/",
        "targeted_flags": [
          "-v",
          "--tb=short"
        ],
        "full_flags": [
          "-x",
          "--tb=short",
          "-q"
        ],
        "ignore": []
      }
    },
    "type_checker": "pyright",
    "linter": null
  },
  "gate": {
    "test_map": {
      "vector.py": [
        "tests/engine/test_math.py"
      ],
      "quaternion.py": [
        "tests/engine/test_math.py"
      ],
      "mathf.py": [
        "tests/engine/test_math.py"
      ],
      "core.py": [
        "tests/engine/test_core.py"
      ],
      "transform.py": [
        "tests/engine/test_transform.py"
      ],
      "lifecycle.py": [
        "tests/engine/test_lifecycle.py"
      ],
      "input_manager.py": [
        "tests/engine/test_input.py"
      ],
      "time_manager.py": [
        "tests/engine/test_time.py"
      ],
      "physics_manager.py": [
        "tests/engine/test_physics.py"
      ],
      "rigidbody.py": [
        "tests/engine/test_physics.py"
      ],
      "collider.py": [
        "tests/engine/test_physics.py"
      ],
      "renderer.py": [
        "tests/engine/test_rendering.py"
      ],
      "camera.py": [
        "tests/engine/test_rendering.py"
      ],
      "display.py": [
        "tests/engine/test_rendering.py"
      ],
      "mapping.py": [
        "tests/reference/test_mapping.py"
      ],
      "csharp_parser.py": [
        "tests/translator/test_csharp_parser.py"
      ],
      "csharp_to_python.py": [
        "tests/translator/test_csharp_to_python.py"
      ],
      "python_to_csharp.py": [
        "tests/translator/test_python_to_csharp.py"
      ],
      "type_mapper.py": [
        "tests/translator/test_csharp_to_python.py",
        "tests/translator/test_python_to_csharp.py"
      ]
    },
    "shared_files": [
      "src/translator/rules/translation_rules.json",
      "src/translator/rules/type_mappings.json",
      "src/engine/core.py",
      "src/engine/math/vector.py"
    ],
    "secrets_scan": true,
    "denylist": [
      "\\.env",
      ".*\\.pem$",
      ".*\\.key$",
      "credentials\\.",
      "id_rsa",
      "id_ed25519"
    ],
    "manager_review": {
      "enabled": true,
      "model": "sonnet",
      "trigger": "always",
      "auto_approve_threshold": 3,
      "escalation_patterns": [
        "security",
        "translation-accuracy",
        "roundtrip-fidelity",
        "breaking-change"
      ]
    }
  },
  "harness": {
    "max_iterations": 20,
    "gate_mode": "warn",
    "timeout_seconds": 1800,
    "max_files_per_iteration": 20,
    "consecutive_fail_threshold": 3,
    "agent_model": {
      "default": "sonnet",
      "critical_tasks": "opus"
    },
    "pause_on_signals": [
      "NEEDS_REVIEW",
      "SPAWN_REQUESTED"
    ]
  },
  "context": {
    "recent_activity_count": 5,
    "max_context_lines": 600,
    "plan_file": "plan.md",
    "activity_file": "activity.md",
    "prompt_file": "PROMPT.md"
  },
  "alerts": {
    "enabled": true,
    "methods": [
      "file"
    ],
    "alert_on": [
      "gate_fail_3x",
      "blocked",
      "complete",
      "timeout",
      "needs_human"
    ],
    "alert_file": ".ralph/alerts.log"
  },
  "observations": {
    "enabled": true,
    "sync_to_global": true
  }
}
